# Sprache / Locale (de oder en)
LOCALE=de

# Pfad zur .env-Datei (fuer supervisord-Setups mit mehreren Instanzen)
# DOTENV_PATH=/var/www/virtual/$USER/kann_ai_bot/.env.de

# Mastodon
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=your_access_token_here
MASTODON_HANDLE=@kannki@mastodon.social

# Bluesky (optional)
BLUESKY_HANDLE=kannki.bsky.social
BLUESKY_APP_PASSWORD=your_app_password_here

# Website
WEBSITE_URL=https://kann-ki.schneuer.online
SITE_NAME=Kann KI?
OTHER_LOCALE_URL=https://can-ai.schneuer.online

# Datenbank (absoluter Pfad empfohlen fuer Produktion)
DB_PATH=kann_ai.db

# Bot-Intervall (in Minuten)
BOT_MIN_INTERVAL=30
BOT_MAX_INTERVAL=120

# WikiHow-Scraper (optional, Standardwerte fuer DE)
WIKIHOW_SITEMAP_URL=https://de.wikihow.com/sitemap.xml
WIKIHOW_DOMAIN=de.wikihow.com
QUESTION_PREFIX=Kann KI
