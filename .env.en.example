LOCALE=en

# Path to this .env file — only needed when running multiple instances from one repo
# DOTENV_PATH=/home/user/repos/kann_ai_bot/.env.en

# Mastodon (optional — bot skips Mastodon if not set)
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=your_access_token_here
MASTODON_HANDLE=@canai@mastodon.social
# Mastodon poll duration in hours
MASTODON_POLL_DURATION_HOURS=168

# Bluesky (optional — bot skips Bluesky if not set)
BLUESKY_HANDLE=canai.bsky.social
BLUESKY_APP_PASSWORD=your_app_password_here

# Website
WEBSITE_URL=https://can-ai.example.com
SITE_NAME=Can AI?
OTHER_LOCALE_URL=https://kann-ki.example.com

# Database — use an absolute path in production
DB_PATH=kann_ai_en.db

# Bot posting interval in minutes
BOT_MIN_INTERVAL=30
BOT_MAX_INTERVAL=120

# WikiHow scraper
WIKIHOW_SITEMAP_URL=https://en.wikihow.com/sitemap.xml
WIKIHOW_DOMAIN=www.wikihow.com
QUESTION_PREFIX=Can AI
